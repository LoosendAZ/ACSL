    public static String vanity(String input){
        char[] list = input.toCharArray();
        int l = 0;
        int space = 0;
        int n = 0;
        for(int i = 0; i < input.length(); i++){
            if(Character.isLetter(list[i])){
                l = l + 1;
            }
            else if(Character.isDigit(list[i])){
                n = n + 1;
            }
            else if(list[i] == ' ' || list[i] == '-'){
                space = space + 1;
            }
        }
        if(l + n <= 7){
            if(space == 1){
                int co = 0;
                for(int i = 0; i < 2; i++){
                    if(Character.isLetter(list[i])){
                        co = co + 1;
                    }
                }
                if(co >= 2){
                    return "V";
                }
            }
        }
        
        
        
        return "IV";
    }
