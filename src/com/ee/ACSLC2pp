    public static String verifyPlate(String plate) {

        if((plate).length() == 7){
            for(int i = 0; i < plate.length(); i++){
                if(plate.charAt(i) == '-'){
                    return g6(plate);
                }
            }
            
            return g7(plate);
        }
        else if((plate).length() == 6){
            return g6(plate);
        }
        else if(plate.length() == 8){
            return g7(plate);
        }
        
        else{
            return vanity(plate);
        }
    }
    public static String g6(String input){
        int letters = 0;
        int numbers = 0;
        int dashes = 0;
        char[] list = input.toCharArray();
        for(int i = 0; i < input.length(); i++){
            char c = input.charAt(i);
            if(Character.isLetter(c)){
                letters = letters + 1;
            } 
            else if(Character.isDigit(c)){
                numbers = numbers + 1;
            }
            else if (c== '-'){
                dashes = dashes + 1;
            }
        }
        //g6A
        if(numbers == 6){
            return "G6A";
        }
        //g6b
        else if(letters == 4 && numbers == 2 && dashes == 1){
            if(Character.isLetter(list[0]) && Character.isLetter(list[1]) && Character.isLetter(list[2])){
                int ltn = 0;
                int ltl = 0;
                int other = 0;
                for(int i = 4; i < 7; i++){
                    char m = input.charAt(i);
                    if(Character.isLetter(m)){
                        ltl = ltl + 1;
                    } 
                    else if(Character.isDigit(m)){
                        ltn = ltn + 1;
                    }
                    else if (m == '-'){
                        other = other + 1;
                    }
                }
                if(ltn == 2 && ltl == 1){
                    return "G6B";
                }
            }
        }
        //g6c
        else if(letters == 3 && numbers == 3 && dashes == 1){
            if(Character.isLetter(list[0]) && Character.isLetter(list[1]) && Character.isLetter(list[2])){
                if(list[3] == '-' && Character.isDigit(list[4]) && Character.isDigit(list[5]) && Character.isDigit(list[6])){
                    return "G6C";
                }
            }
            else if(Character.isDigit(list[0]) && Character.isDigit(list[1]) && Character.isDigit(list[2])){
                if(list[3] == '-' && Character.isLetter(list[4]) && Character.isLetter(list[5]) && Character.isLetter(list[6])){
                    return "G6D";
                }
            }
        }
        
        return vanity(input);

    }
    
    
